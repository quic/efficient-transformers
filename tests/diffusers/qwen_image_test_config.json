{
  "model_setup": {
    "height": 64,
    "width": 64,
    "num_transformer_layers": 2,
    "attention_head_dim": 8,
    "num_attention_heads": 2,
    "joint_attention_dim": 32,
    "max_sequence_length": 128
  },
  "mad_validation": {
    "tolerances": {
      "transformer": 3.5,
      "vae_decoder": 0.7
    }
  },
  "pipeline_params": {
